#################################################################
                        # KEY BINDINGS
#################################################################

#################################################################
# SUPER + FUNCTION KEYS
#################################################################

#Rofi (all)
super + F12
    rofi -show run

#################################################################
# SUPER + ... KEYS
#################################################################

#Krita
super + k
    krita

#Browser
super + w
    brave-browser-nightly

#Appearance
super + c
    lxappearance

#Rofi (apps)
super + r
    rofi -show drun

#Tor
super + t
    tor-browser

#Visual Studio Code
super + v
    code

#Terminal
super + Return
    alacritty

#OBS
super + i
    obs
    
#Xkill
super + Escape
    xkill

#Sublime Text
super + s
    subl4

#Spotify
super + p
    spotify

#Discord
super + d
    discord

#################################################################
# SUPER + SHIFT KEYS
#################################################################

#File-Manager
super + shift + Return
	nemo

#reload sxhkd:
super + shift + s
	pkill -USR1 -x sxhkd

#################################################################
#     SCREENSHOTS
#################################################################

#Scrot
Print
    scrot 'Screenshot-%Y-%m-%d.jpg' -e 'mv $f $$(xdg-user-dir PICTURES)'

#screeenshooter
ctrl + Print
     xfce4-screenshooter

#################################################################
#     MULTIMEDIA KEYS
#################################################################

#Raises volume
XF86AudioRaiseVolume
    amixer set Master 2%+

#Lowers volume
XF86AudioLowerVolume
    amixer set Master 2%-

#Mute
XF86AudioMute
  /usr/bin/amixer set Master toggle 

#PLAY
XF86AudioPlay
    playerctl play-pause

#Next
XF86AudioNext
    playerctl next

#previous
XF86AudioPrev
    playerctl previous

#Stop
XF86AudioStop
    playerctl stop

#Brightness up
XF86MonBrightnessUp
    xbacklight -inc 10

#Brightness down
XF86MonBrightnessDown
    xbacklight -dec 10

#Picom Toggle
ctrl + alt + o
    ~/.config/qtile/scripts/picom-toggle.sh
